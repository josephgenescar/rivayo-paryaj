# Backend environment example for Rivayo Paryaj
# Use Supabase Postgres connection string for DATABASE_URL
# You can find the connection string in Supabase -> Settings -> Database -> Connection string (Postgres)

# Primary Postgres connection (set this to your Supabase Postgres connection string)
DATABASE_URL=postgres://USER:PASS@HOST:PORT/DATABASE

# JWT secret for signing tokens
JWT_SECRET=your_jwt_secret_here

# RapidAPI key (optional, used for live football API)
RAPIDAPI_KEY=

# Cashback config (optional)
CASHBACK_MIN_LOSS=500
CASHBACK_MAX_AMOUNT=200
CASHBACK_PERCENT=10

# Optional Supabase info (if you plan to use supabase-js later)
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are only needed if you integrate with the
# Supabase JS client (server-side). Keep Service Role key secret.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Control SSL verification behavior. Default is strict verification.
# Set to "no-verify" only if you understand the risk and need to skip cert verification.
PGSSLMODE=strict

# Comma-separated list of allowed CORS origins for the API (override defaults)
# e.g. ALLOWED_ORIGINS=https://myapp.com,http://localhost:3000
ALLOWED_ORIGINS=https://rivayo-paryaj.vercel.app,http://localhost:3000,http://localhost:3002
