# ============================================================
# RIVAYO PARYAJ - Fichye Konfigirasyon
# Kopye fichye sa epi rename li .env
# PA janm mete .env sou GitHub!
# ============================================================

# ---- BASE DONE POSTGRESQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rivayo_db
DB_USER=postgres
DB_PASS=Mike509..

# ---- SEKIRITE JWT ----
# Chanje string sa pou yon sekrè fò (omwen 32 karaktè)
JWT_SECRET=rivayo_sekre_ayiti_2025_chanje_mwen_tanpri

# ---- PÒ SÈVÈ ----
PORT=3001

# ---- MONCASH API (Digicel Business) ----
# Kontakte Digicel Business: +509 37-27-0000 oswa ale Delmas 75
# Yo ap ba ou clientId ak clientSecret apre w enskri kòm marchann
MONCASH_CLIENT_ID=mete_client_id_ou_la
MONCASH_CLIENT_SECRET=mete_client_secret_ou_la

# MONCASH_MODE=sandbox   ← pou teste
# MONCASH_MODE=live      ← pou pwodiksyon reyèl
MONCASH_MODE=sandbox

# URL Sandbox: https://sandbox.moncashbutton.digicelgroup.com
# URL Live:    https://moncashbutton.digicelgroup.com
MONCASH_BASE_URL=https://sandbox.moncashbutton.digicelgroup.com

# ---- CASHBACK SEMÈN (Remèt 10% sou Pèt) ----
# Minimòm pèt pou kalifyé cashback
CASHBACK_MIN_LOSS=500
# Maksimòm cashback pa itilizatè pa semèn
CASHBACK_MAX_AMOUNT=200
# Pousantaj (10 = 10%)
CASHBACK_PERCENT=10
